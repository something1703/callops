# Backend environment variables
# Copy this file to .env and fill in all values. Never commit the actual .env.

# From Neon dashboard — use the app_role connection string after running setup-roles.sql
DATABASE_URL=postgres://app_role:<password>@<neon-host>/<db>?sslmode=require

# Google OAuth — from Google Cloud Console (OAuth 2.0 Client ID for Web)
GOOGLE_CLIENT_ID=

# Optional: restrict login to a specific Google Workspace domain (e.g., yourcompany.com)
# Leave blank to allow any Google account
ALLOWED_EMAIL_DOMAIN=

# Random 256-bit hex string — run: openssl rand -hex 32
JWT_SECRET=

# Random 256-bit hex string — shared between this backend and the Lambda ingest function
# run: openssl rand -hex 32
SERVICE_TO_SERVICE_SECRET=

# AWS credentials — for S3 uploads and Lambda triggers (Phase 2+)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=

# Server
PORT=4000
