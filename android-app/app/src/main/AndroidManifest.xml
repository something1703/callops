<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Network ──────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── Telephony (Phase 3) ──────────────────────────────────────────────── -->
    <!--
        MANAGE_OWN_CALLS: lets us register a PhoneAccount and place calls via
        TelecomManager.placeCall() WITHOUT requiring the user to set us as their
        default dialer. InCallService still needs the dialer role for full custom UI;
        if the role is denied, calls still work through the system dialer UI.
    -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.WRITE_CALL_LOG" />

    <!-- ── Audio recording (best-effort — see CallAudioRecorder.kt) ─────────── -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ── Screen wake on incoming call screen ──────────────────────────────── -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CallOps"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ── Main entry point ────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Launcher icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                These DIAL intent filters are REQUIRED for the system to recognise
                CallOps as a potential default phone/dialer app.
                Without them, CallOps never appears in:
                  Settings → Apps → Default apps → Phone app
                and RoleManager.createRequestRoleIntent(ROLE_DIALER) silently fails.
            -->
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <data android:scheme="tel" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <data android:scheme="tel" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
            </intent-filter>
        </activity>


        <!-- ── In-call screen — launched by InCallService ─────────────────── -->
        <activity
            android:name=".ui.InCallActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance" />

        <!--
            ConnectionService: manages outgoing call lifecycle.
            Requires BIND_TELECOM_CONNECTION_SERVICE permission so only the
            system telecom framework can bind to it.
        -->
        <service
            android:name=".telecom.CallOpsConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <!--
            InCallService: provides the custom in-call UI when we are the
            default dialer. If we are NOT the default dialer, the system
            dialer UI is used instead — no crash, just no custom screen.
        -->
        <service
            android:name=".telecom.CallOpsInCallService"
            android:exported="true"
            android:permission="android.permission.BIND_IN_CALL_SERVICE">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true" />
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
        </service>

    </application>

</manifest>
