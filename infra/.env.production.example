# .env.production.example — CallOps VPS environment template
# Copy this file to .env.production on the VPS and fill in all values.
# NEVER commit .env.production to git.

# ── Database (Neon) ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require

# ── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_SECRET
JWT_SECRET=generate_with__openssl_rand_hex_32

# Optional: restrict logins to a single Google Workspace domain
ALLOWED_EMAIL_DOMAIN=

# ── Service-to-service (ETL → Backend) ───────────────────────────────────────
SERVICE_TO_SERVICE_SECRET=generate_with__openssl_rand_hex_32

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=ap-south-1
S3_BUCKET=callops-data-lake-rvsr
CALLS_BUCKET=callops-events-rvsr

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
ALLOWED_ORIGIN=https://callops.yourdomain.com

# ── Admin Web (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.callops.yourdomain.com

# ── Metabase (read-only Neon role — run setup-readonly-role.sql first) ────────
METABASE_DB_HOST=YOUR_NEON_HOST
METABASE_DB_PORT=5432
METABASE_DB_NAME=neondb
METABASE_DB_USER=metabase_reader
METABASE_DB_PASS=YOUR_METABASE_READER_PASSWORD
